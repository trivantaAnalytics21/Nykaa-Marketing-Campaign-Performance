      <aliases enabled='yes' />
      <column caption='Acquisition Cost' datatype='real' name='[Acquisition_Cost]' role='measure' type='quantitative' />
      <column caption='CTR' datatype='real' name='[Calculation_1817767658549251]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Clicks]) / SUM([Impressions])' />
      </column>
      <column caption='Conversion Rate' datatype='real' name='[Calculation_1817767658795012]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Conversions]) / SUM([Clicks])' />
      </column>
      <column caption='Current Revenue' datatype='integer' name='[Calculation_1817767682355205]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Revenue])' />
      </column>
      <column caption='Previous Month Revenue' datatype='integer' name='[Calculation_1817767682572294]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='LOOKUP(SUM([Revenue]),-1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Revenue Growth %' datatype='real' name='[Calculation_1817767682699271]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Revenue]) - LOOKUP(SUM([Revenue]),-1))&#13;&#10;/&#13;&#10;LOOKUP(SUM([Revenue]),-1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Month' datatype='integer' name='[Calculation_1817767683051528]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MONTH([Date])' />
      </column>
      <column caption='Latest Month Filter' datatype='boolean' name='[Calculation_1817767684341769]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;,[Date])&#13;&#10;=&#13;&#10;{ MAX(DATETRUNC(&apos;month&apos;,[Date])) }' />
      </column>
      <column caption='Growth Indicator' datatype='string' name='[Calculation_1817767684812810]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_1817767682699271] &gt; 0 THEN &quot;▲ Growth&quot;&#13;&#10;ELSE &quot;▼ Decline&quot;&#13;&#10;END'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='KPI Label' datatype='string' name='[Calculation_1817767685013515]' role='measure' type='nominal'>
        <calculation class='tableau' formula='&quot;Revenue&quot; +&#13;&#10;CHAR(10) +&#13;&#10;&quot;₹&quot; + STR(ROUND(SUM([Revenue])/1000000,2)) + &quot;M&quot;&#13;&#10;+&#13;&#10;CHAR(10) +&#13;&#10;IF [Calculation_1817767682699271] &gt; 0 THEN&#13;&#10;&quot;▲ &quot;&#13;&#10;ELSE&#13;&#10;&quot;▼ &quot;&#13;&#10;END&#13;&#10;+&#13;&#10;STR(ROUND([Calculation_1817767682699271]*100,2))&#13;&#10;+&#13;&#10;&quot;% vs Previous Month&quot;'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Sum Of Conversions' datatype='real' name='[Calculation_1817767685611532]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Conversions]) - LOOKUP(SUM([Conversions]),-1))&#13;&#10;/&#13;&#10;LOOKUP(SUM([Conversions]),-1)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Funnel Stage' datatype='string' name='[Calculation_1817767706337295]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Impressions&quot;' />
      </column>
      <column caption='One ' datatype='integer' name='[Calculation_1817767709376528]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1' />
      </column>
